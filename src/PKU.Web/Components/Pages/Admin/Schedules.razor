@page "/admin/schedules"
@attribute [Authorize(Roles = "Administrator")]
@using PKU.Domain.Entities
@using PKU.Domain.Enums
@rendermode InteractiveServer

<PageTitle>Definiowanie terminarzy</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="mb-0">Definiowanie terminarzy</h3>
    <button class="btn btn-primary" @onclick="AddSchedule">Dodaj terminarz</button>
</div>

<div class="row mb-3 align-items-end">
    <div class="col-auto">
        <label class="form-label fw-bold">Typ oplaty</label>
        <select class="form-select form-select-sm" @bind="_filterFeeType" @bind:after="ApplyFilter">
            <option value="">Wszystkie</option>
            @foreach (var ft in Enum.GetValues<FeeType>())
            {
                <option value="@ft">@ft</option>
            }
        </select>
    </div>
    <div class="col-auto">
        <label class="form-label fw-bold">Typ kontrahenta</label>
        <select class="form-select form-select-sm" @bind="_filterContractorType" @bind:after="ApplyFilter">
            <option value="">Wszystkie</option>
            @foreach (var ct in Enum.GetValues<ContractorType>())
            {
                <option value="@ct">@GetContractorTypeLabel(ct)</option>
            }
        </select>
    </div>
    <div class="col-auto">
        <label class="form-label fw-bold">Skladanie osw. (dni)</label>
        <div class="d-flex gap-1">
            <input type="number" class="form-control form-control-sm" style="width:70px" placeholder="od" @bind="_filterSubmitMin" @bind:after="ApplyFilter" />
            <input type="number" class="form-control form-control-sm" style="width:70px" placeholder="do" @bind="_filterSubmitMax" @bind:after="ApplyFilter" />
        </div>
    </div>
    <div class="col-auto">
        <label class="form-label fw-bold">Faktura (dni)</label>
        <div class="d-flex gap-1">
            <input type="number" class="form-control form-control-sm" style="width:70px" placeholder="od" @bind="_filterInvoiceMin" @bind:after="ApplyFilter" />
            <input type="number" class="form-control form-control-sm" style="width:70px" placeholder="do" @bind="_filterInvoiceMax" @bind:after="ApplyFilter" />
        </div>
    </div>
    <div class="col-auto">
        <label class="form-label fw-bold">Korekta (dni)</label>
        <div class="d-flex gap-1">
            <input type="number" class="form-control form-control-sm" style="width:70px" placeholder="od" @bind="_filterCorrectionMin" @bind:after="ApplyFilter" />
            <input type="number" class="form-control form-control-sm" style="width:70px" placeholder="do" @bind="_filterCorrectionMax" @bind:after="ApplyFilter" />
        </div>
    </div>
    <div class="col-auto">
        <label class="form-label fw-bold">Fakt. po kor. (dni)</label>
        <div class="d-flex gap-1">
            <input type="number" class="form-control form-control-sm" style="width:70px" placeholder="od" @bind="_filterCorrInvoiceMin" @bind:after="ApplyFilter" />
            <input type="number" class="form-control form-control-sm" style="width:70px" placeholder="do" @bind="_filterCorrInvoiceMax" @bind:after="ApplyFilter" />
        </div>
    </div>
    <div class="col-auto">
        <label class="form-label fw-bold">Aktywny</label>
        <select class="form-select form-select-sm" @bind="_filterActive" @bind:after="ApplyFilter">
            <option value="">Wszystkie</option>
            <option value="true">Tak</option>
            <option value="false">Nie</option>
        </select>
    </div>
</div>

@if (_filtered is not null && _filtered.Any())
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Typ oplaty</th>
                <th>Typ kontrahenta</th>
                <th>Skladanie oswiadczenia</th>
                <th>Wystawienie faktury</th>
                <th>Korekta oswiadczenia</th>
                <th>Faktura po korekcie</th>
                <th>Aktywny</th>
                <th>Akcje</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var schedule in _filtered)
            {
                <tr>
                    <td>@schedule.FeeType</td>
                    <td>@GetContractorTypeLabel(schedule.ContractorType)</td>
                    <td>@FormatItem(schedule, ScheduleItemType.DeclarationSubmit)</td>
                    <td>@FormatItem(schedule, ScheduleItemType.DeclarationInvoice)</td>
                    <td>@FormatItem(schedule, ScheduleItemType.DeclarationCorrection)</td>
                    <td>@FormatItem(schedule, ScheduleItemType.DeclarationCorrectionInvoice)</td>
                    <td>@(schedule.IsActive ? "Tak" : "Nie")</td>
                    <td>
                        <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => EditSchedule(schedule.Id)">Edytuj</button>
                        <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteSchedule(schedule.Id)">Usun</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <div class="alert alert-info">Brak terminarzy dla wybranych filtrow.</div>
}

@if (_confirmDeleteId is not null)
{
    <div class="modal d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Potwierdzenie usuniecia</h5>
                </div>
                <div class="modal-body">
                    <p>Czy na pewno chcesz usunac ten terminarz?</p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CancelDelete">Anuluj</button>
                    <button class="btn btn-danger" @onclick="ConfirmDelete">Usun</button>
                </div>
            </div>
        </div>
    </div>
}
