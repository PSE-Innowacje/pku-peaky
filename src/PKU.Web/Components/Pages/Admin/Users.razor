@page "/admin/users"
@attribute [Authorize(Roles = "Administrator")]
@using PKU.Domain.Enums
@rendermode InteractiveServer

<PageTitle>Uzytkownicy</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="mb-0">Uzytkownicy</h3>
    <button class="btn btn-primary" @onclick="@(() => Navigation.NavigateTo("/admin/users/new"))">
        Dodaj uzytkownika
    </button>
</div>

<div class="row mb-3 align-items-end">
    <div class="col-auto">
        <label class="form-label fw-bold">Imie / nazwisko</label>
        <input type="text" class="form-control form-control-sm" placeholder="Szukaj..." @bind="_filterName" @bind:event="oninput" @bind:after="ApplyFilter" />
    </div>
    <div class="col-auto">
        <label class="form-label fw-bold">Email</label>
        <input type="text" class="form-control form-control-sm" placeholder="Szukaj..." @bind="_filterEmail" @bind:event="oninput" @bind:after="ApplyFilter" />
    </div>
    <div class="col-auto">
        <label class="form-label fw-bold">Rola</label>
        <select class="form-select form-select-sm" @bind="_filterRole" @bind:after="ApplyFilter">
            <option value="">Wszystkie</option>
            <option value="Administrator">Administrator</option>
            <option value="Kontrahent">Kontrahent</option>
        </select>
    </div>
    <div class="col-auto">
        <label class="form-label fw-bold">Typ kontrahenta</label>
        <select class="form-select form-select-sm" @bind="_filterContractorType" @bind:after="ApplyFilter">
            <option value="">Wszystkie</option>
            @foreach (var ct in Enum.GetValues<ContractorType>())
            {
                <option value="@ct">@ct</option>
            }
        </select>
    </div>
    <div class="col-auto">
        <label class="form-label fw-bold">Aktywny</label>
        <select class="form-select form-select-sm" @bind="_filterActive" @bind:after="ApplyFilter">
            <option value="">Wszystkie</option>
            <option value="true">Tak</option>
            <option value="false">Nie</option>
        </select>
    </div>
</div>

@if (_confirmDeleteUser is not null)
{
    <div class="alert alert-warning d-flex align-items-center justify-content-between">
        <span>Czy na pewno chcesz usunac uzytkownika <strong>@_confirmDeleteUser.Email</strong>?</span>
        <span>
            <button class="btn btn-sm btn-danger me-2" @onclick="ConfirmDelete">Usun</button>
            <button class="btn btn-sm btn-outline-secondary" @onclick="CancelDelete">Anuluj</button>
        </span>
    </div>
}

<table class="table table-striped">
    <thead>
        <tr>
            <th>Imie i nazwisko</th>
            <th>Email</th>
            <th>Rola</th>
            <th>Typ kontrahenta</th>
            <th>Aktywny</th>
            <th>Akcje</th>
        </tr>
    </thead>
    <tbody>
        @if (_filtered is not null)
        {
            @foreach (var user in _filtered)
            {
                <tr>
                    <td>@user.FullName</td>
                    <td>@user.Email</td>
                    <td>@user.Role</td>
                    <td>@string.Join(", ", user.ContractorTypes)</td>
                    <td>@(user.IsActive ? "Tak" : "Nie")</td>
                    <td>
                        <button class="btn btn-sm btn-outline-primary me-1" @onclick="@(() => Navigation.NavigateTo($"/admin/users/{user.Id}"))">Edytuj</button>
                        <button class="btn btn-sm btn-outline-danger" @onclick="@(() => RequestDelete(user))">Usun</button>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>
