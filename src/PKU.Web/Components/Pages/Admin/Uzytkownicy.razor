@page "/admin/uzytkownicy"
@using PKU.Application.Interfaces
@inject IUserService UserService
@rendermode InteractiveServer

<PageTitle>Uzytkownicy</PageTitle>

<h3>Uzytkownicy</h3>
<p>Zarzadzanie uzytkownikami systemu.</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Imie i nazwisko</th>
            <th>Email</th>
            <th>Rola</th>
            <th>Aktywny</th>
            <th>Akcje</th>
        </tr>
    </thead>
    <tbody>
        @if (_users is not null)
        {
            @foreach (var user in _users)
            {
                <tr>
                    <td>@user.Name</td>
                    <td>@user.Email</td>
                    <td>@user.Role</td>
                    <td>@(user.IsActive ? "Tak" : "Nie")</td>
                    <td>
                        <button class="btn btn-sm btn-outline-primary">Edytuj</button>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>

@code {
    private IEnumerable<PKU.Domain.Entities.User>? _users;

    protected override async Task OnInitializedAsync()
    {
        _users = await UserService.GetAllAsync();
    }
}
