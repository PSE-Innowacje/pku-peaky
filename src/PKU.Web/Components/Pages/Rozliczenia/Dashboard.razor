@page "/rozliczenia/dashboard"
@attribute [Authorize(Roles = "Kontrahent,Administrator")]
@using System.Security.Claims
@using PKU.Application.Interfaces
@using PKU.Domain.Entities
@using PKU.Domain.Enums
@using PKU.Domain.Services
@inject IDeclarationService DeclarationService
@inject IUserService UserService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Dashboard oswiadczen</PageTitle>

<div class="dashboard-header mb-4">
    <h3 class="mb-1">Dashboard oswiadczen</h3>
    @if (_user is not null && _user.Role == UserRole.Kontrahent)
    {
        <p class="text-muted mb-0">
            Kontrahent: <strong>@_user.FullName</strong> &middot; Typ: <strong>@string.Join(", ", _user.ContractorTypes)</strong>
        </p>
    }
    <div class="d-flex align-items-center gap-3 mt-2">
        <label class="text-muted mb-0">Okres:</label>
        <select class="form-select form-select-sm" style="width: auto;" @onchange="OnYearChanged" value="@_selectedYear">
            @for (int y = DateTime.Now.Year; y >= DateTime.Now.Year - 5; y--)
            {
                <option value="@y">@y</option>
            }
        </select>
        <select class="form-select form-select-sm" style="width: auto;" @onchange="OnMonthChanged" value="@_selectedMonth">
            <option value="0">Wszystkie</option>
            @for (int m = 1; m <= 12; m++)
            {
                <option value="@m">@GetMonthName(m)</option>
            }
        </select>
    </div>
</div>

@if (_totalCount == 0 && _user is not null && _user.Role == UserRole.Kontrahent && _selectedMonth > 0)
{
    <div class="alert alert-warning d-flex align-items-center">
        <span class="me-2" style="font-size:1.5rem;">&#9888;</span>
        <div class="flex-grow-1">
            <strong>Brak oswiadczen dla biezacego okresu.</strong> Wygeneruj oswiadczenia, aby rozpoczac prace.
        </div>
        <button class="btn btn-success ms-3" @onclick="GenerateDeclarationsAsync" disabled="@_generating">
            @if (_generating)
            {
                <span class="spinner-border spinner-border-sm me-1" role="status"></span>
            }
            Generuj oswiadczenia
        </button>
    </div>
}

@if (_loading)
{
    <div class="text-center my-4">
        <div class="spinner-border text-primary" role="status"></div>
        <p class="text-muted mt-2">Ladowanie danych...</p>
    </div>
}

@* ===== SUMMARY CARDS ===== *@
<div class="row g-3 mb-4" style="@(_loading ? "opacity: 0.5; pointer-events: none;" : "")">
    <div class="col-lg-4 col-md-6" role="button" @onclick="GoToAll">
        <div class="dash-card dash-card-total">
            <div class="dash-card-icon">&#128203;</div>
            <div class="dash-card-body">
                <div class="dash-card-value">@_totalCount</div>
                <div class="dash-card-label">Wszystkie</div>
            </div>
        </div>
    </div>
    <div class="col-lg-4 col-md-6" role="button" @onclick="GoToNotSubmitted">
        <div class="dash-card dash-card-notsubmitted">
            <div class="dash-card-icon">&#128196;</div>
            <div class="dash-card-body">
                <div class="dash-card-value">@_nieZlozoneCount</div>
                <div class="dash-card-label">Nie zlozone</div>
            </div>
        </div>
    </div>
    <div class="col-lg-4 col-md-6" role="button" @onclick="GoToSubmitted">
        <div class="dash-card dash-card-submitted">
            <div class="dash-card-icon">&#10004;</div>
            <div class="dash-card-body">
                <div class="dash-card-value">@_zlozoneCount</div>
                <div class="dash-card-label">Zlozone</div>
            </div>
        </div>
    </div>
</div>

@* ===== PROGRESS BAR ===== *@
<div class="card mb-4 shadow-sm">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <h6 class="mb-0">Postep realizacji</h6>
            <span class="badge bg-dark fs-6">@_completionPercent%</span>
        </div>
        <div class="progress" style="height: 24px;">
            <div class="progress-bar bg-success" role="progressbar"
                 style="width: @_completionPercent%;"
                 aria-valuenow="@_completionPercent" aria-valuemin="0" aria-valuemax="100">
                Zlozone (@_zlozoneCount)
            </div>
        </div>
        <div class="d-flex justify-content-between mt-1">
            <small class="text-muted">@_zlozoneCount z @_totalCount oswiadczen zlozonych</small>
            <small class="text-muted">@_nieZlozoneCount pozostalych do zlozenia</small>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    @* ===== LEFT COLUMN: STATUS DONUT + DEADLINES ===== *@
    <div class="col-lg-4">
        @* --- Donut Chart --- *@
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-white">
                <h6 class="mb-0">Rozklad statusow</h6>
            </div>
            <div class="card-body d-flex flex-column align-items-center">
                <div class="donut-chart" style="@GetDonutStyle()">
                    <div class="donut-center">
                        <span class="donut-center-value">@_completionPercent%</span>
                        <span class="donut-center-label">ukonczono</span>
                    </div>
                </div>
                <div class="d-flex gap-3 mt-3 flex-wrap justify-content-center">
                    <span class="d-flex align-items-center gap-1"><span class="legend-dot bg-danger"></span> Nie zlozone (@_nieZlozoneCount)</span>
                    <span class="d-flex align-items-center gap-1"><span class="legend-dot bg-success"></span> Zlozone (@_zlozoneCount)</span>
                </div>
            </div>
        </div>

        @* --- Deadline Alerts --- *@
        <div class="card shadow-sm">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <h6 class="mb-0">Terminy</h6>
                @if (_overdueCount > 0)
                {
                    <span class="badge bg-danger">@_overdueCount przeterminowanych</span>
                }
            </div>
            <div class="card-body p-0">
                @if (_deadlineAlerts.Any())
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var alert in _deadlineAlerts.Take(6))
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center @(alert.IsOverdue ? "list-group-item-danger" : alert.DaysLeft <= 3 ? "list-group-item-warning" : "")">
                                <div>
                                    <small class="fw-bold">@alert.FeeTypeName</small><br />
                                    <small class="text-muted">@alert.DeclarationNumber</small>
                                </div>
                                <div class="text-end">
                                    @if (alert.IsOverdue)
                                    {
                                        <span class="badge bg-danger">Przeterminowane</span>
                                    }
                                    else if (alert.DaysLeft <= 3)
                                    {
                                        <span class="badge bg-warning text-dark">@alert.DaysLeft dni</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">@alert.DaysLeft dni</span>
                                    }
                                    <br />
                                    <small class="text-muted">@alert.Deadline.ToString("dd.MM.yyyy")</small>
                                </div>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <div class="p-3 text-muted text-center">Brak terminow do wyswietlenia</div>
                }
            </div>
        </div>
    </div>

    @* ===== RIGHT COLUMN: FEE TYPE TABLE + CATEGORY BREAKDOWN ===== *@
    <div class="col-lg-8">
        @* --- Fee Type Breakdown Table --- *@
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-white">
                <h6 class="mb-0">Rozbicie wg typu oplaty</h6>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Typ oplaty</th>
                                <th>Kategoria</th>
                                <th class="text-center">Nie zlozone</th>
                                <th class="text-center">Zlozone</th>
                                <th class="text-center">Razem</th>
                                <th style="width: 150px;">Postep</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in _feeTypeRows)
                            {
                                <tr>
                                    <td><strong>@row.FeeTypeName</strong></td>
                                    <td><span class="badge @(row.Category == "Pozaprzesylowa" ? "bg-info" : "bg-secondary") bg-opacity-75">@row.Category</span></td>
                                    <td class="text-center">
                                        @if (row.NotSubmitted > 0)
                                        {
                                            <span class="badge bg-danger">@row.NotSubmitted</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">0</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        @if (row.Submitted > 0)
                                        {
                                            <span class="badge bg-success">@row.Submitted</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">0</span>
                                        }
                                    </td>
                                    <td class="text-center fw-bold">@row.Total</td>
                                    <td>
                                        <div class="progress" style="height: 8px;">
                                            <div class="progress-bar bg-success" style="width: @row.SubmittedPercent%;"></div>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        @* --- Category Breakdown --- *@
        <div class="row g-3 mb-4">
            @foreach (var cat in _categoryStats)
            {
                <div class="col-md-6">
                    <div class="card shadow-sm h-100">
                        <div class="card-body">
                            <h6 class="card-title">@cat.CategoryName</h6>
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted">@cat.Submitted / @cat.Total zlozonych</span>
                                <strong>@cat.Percent%</strong>
                            </div>
                            <div class="progress" style="height: 12px;">
                                <div class="progress-bar bg-success" style="width: @cat.Percent%;"></div>
                            </div>
                            <div class="row mt-3 text-center">
                                <div class="col-6">
                                    <div class="fs-5 fw-bold text-danger">@cat.NotSubmitted</div>
                                    <small class="text-muted">Nie zlozone</small>
                                </div>
                                <div class="col-6">
                                    <div class="fs-5 fw-bold text-success">@cat.Submitted</div>
                                    <small class="text-muted">Zlozone</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        @* --- Corrections & Recent Activity --- *@
        <div class="row g-3">
            <div class="col-md-6">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-white">
                        <h6 class="mb-0">Korekty</h6>
                    </div>
                    <div class="card-body">
                        @if (_correctionsCount > 0)
                        {
                            <div class="d-flex align-items-center mb-3">
                                <div class="fs-2 fw-bold text-primary me-3">@_correctionsCount</div>
                                <div class="text-muted">korekt w biezacym okresie</div>
                            </div>
                            <ul class="list-group list-group-flush">
                                @foreach (var corr in _corrections.Take(5))
                                {
                                    <li class="list-group-item px-0 d-flex justify-content-between">
                                        <span>@ContractorFeeMapping.GetFeeTypeName(corr.FeeType)</span>
                                        <span class="badge bg-primary rounded-pill">Korekta #@corr.CorrectionNumber</span>
                                    </li>
                                }
                            </ul>
                        }
                        else
                        {
                            <div class="text-center text-muted py-3">
                                <div style="font-size: 2rem;">&#128077;</div>
                                Brak korekt w tym okresie
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-white">
                        <h6 class="mb-0">Ostatnie zlozenia</h6>
                    </div>
                    <div class="card-body p-0">
                        @if (_recentSubmissions.Any())
                        {
                            <ul class="list-group list-group-flush">
                                @foreach (var sub in _recentSubmissions.Take(6))
                                {
                                    <li class="list-group-item">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <div>
                                                <strong>@ContractorFeeMapping.GetFeeTypeName(sub.FeeType)</strong>
                                                <br />
                                                <small class="text-muted">@sub.DeclarationNumber</small>
                                            </div>
                                            <div class="text-end">
                                                <span class="badge bg-success">Zlozone</span>
                                                <br />
                                                <small class="text-muted">@sub.SubmittedAt?.ToString("dd.MM.yyyy HH:mm")</small>
                                            </div>
                                        </div>
                                    </li>
                                }
                            </ul>
                        }
                        else
                        {
                            <div class="p-3 text-muted text-center">Brak zlozonych oswiadczen</div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private User? _user;
    private List<Declaration> _declarations = new();
    private int _selectedYear = DateTime.Now.Year;
    private int _selectedMonth; // 0 = all months
    private int _totalCount;
    private int _nieZlozoneCount;
    private int _zlozoneCount;
    private int _completionPercent;
    private int _overdueCount;
    private int _correctionsCount;
    private bool _generating;
    private bool _loading;

    private List<FeeTypeRow> _feeTypeRows = new();
    private List<CategoryStat> _categoryStats = new();
    private List<DeadlineAlert> _deadlineAlerts = new();
    private List<Declaration> _corrections = new();
    private List<Declaration> _recentSubmissions = new();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var userId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        if (userId is null) return;

        _user = await UserService.GetByIdAsync(userId);
        if (_user is null) return;

        await LoadDeclarationsAsync();
    }

    private async Task LoadDeclarationsAsync()
    {
        if (_user is null) return;

        _loading = true;
        IEnumerable<Declaration> declarations;

        if (_user.Role == UserRole.Kontrahent)
        {
            declarations = _selectedMonth == 0
                ? await DeclarationService.GetForContractorYearAsync(_user.Id, _selectedYear)
                : await DeclarationService.GetForContractorMonthAsync(_user.Id, _selectedYear, _selectedMonth);
        }
        else
        {
            declarations = await DeclarationService.GetAllAsync();
        }

        _declarations = declarations.ToList();
        ComputeStats();
        _loading = false;
    }

    private async Task OnMonthChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var month))
        {
            _selectedMonth = month;
            await LoadDeclarationsAsync();
        }
    }

    private async Task OnYearChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var year))
        {
            _selectedYear = year;
            await LoadDeclarationsAsync();
        }
    }

    private void ComputeStats()
    {
        _totalCount = _declarations.Count;
        _nieZlozoneCount = _declarations.Count(d => d.Status != DeclarationStatus.Submitted);
        _zlozoneCount = _declarations.Count(d => d.Status == DeclarationStatus.Submitted);

        _completionPercent = _totalCount > 0 ? (int)Math.Round(100.0 * _zlozoneCount / _totalCount) : 0;

        // Fee type breakdown
        _feeTypeRows = _declarations
            .GroupBy(d => d.FeeType)
            .Select(g =>
            {
                var total = g.Count();
                var submitted = g.Count(d => d.Status == DeclarationStatus.Submitted);
                var notSubmitted = total - submitted;
                var category = g.First().FeeCategory;
                return new FeeTypeRow
                {
                    FeeType = g.Key,
                    FeeTypeName = ContractorFeeMapping.GetFeeTypeName(g.Key),
                    Category = ContractorFeeMapping.GetFeeCategoryName(category),
                    Total = total,
                    Submitted = submitted,
                    NotSubmitted = notSubmitted,
                    SubmittedPercent = total > 0 ? (int)Math.Round(100.0 * submitted / total) : 0
                };
            })
            .OrderBy(r => r.FeeTypeName)
            .ToList();

        // Category breakdown
        _categoryStats = _declarations
            .GroupBy(d => d.FeeCategory)
            .Select(g =>
            {
                var total = g.Count();
                var submitted = g.Count(d => d.Status == DeclarationStatus.Submitted);
                var notSubmitted = total - submitted;
                return new CategoryStat
                {
                    CategoryName = ContractorFeeMapping.GetFeeCategoryName(g.Key),
                    Total = total,
                    Submitted = submitted,
                    NotSubmitted = notSubmitted,
                    Percent = total > 0 ? (int)Math.Round(100.0 * submitted / total) : 0
                };
            })
            .ToList();

        // Deadline alerts
        var now = DateTime.Now;
        _deadlineAlerts = _declarations
            .Where(d => d.Deadline.HasValue && d.Status != DeclarationStatus.Submitted)
            .Select(d =>
            {
                var daysLeft = (d.Deadline!.Value - now).Days;
                return new DeadlineAlert
                {
                    DeclarationNumber = d.DeclarationNumber,
                    FeeTypeName = ContractorFeeMapping.GetFeeTypeName(d.FeeType),
                    Deadline = d.Deadline.Value,
                    DaysLeft = daysLeft,
                    IsOverdue = daysLeft < 0
                };
            })
            .OrderBy(a => a.Deadline)
            .ToList();

        _overdueCount = _deadlineAlerts.Count(a => a.IsOverdue);

        // Corrections
        _corrections = _declarations
            .Where(d => d.CorrectionNumber > 0)
            .OrderByDescending(d => d.CorrectionNumber)
            .ToList();
        _correctionsCount = _corrections.Count;

        // Recent submissions
        _recentSubmissions = _declarations
            .Where(d => d.Status == DeclarationStatus.Submitted && d.SubmittedAt.HasValue)
            .OrderByDescending(d => d.SubmittedAt)
            .ToList();
    }

    private async Task GenerateDeclarationsAsync()
    {
        if (_user is null) return;

        _generating = true;
        var declarations = await DeclarationService.CreateMissingDeclarationsAsync(_user.Id, _selectedYear, _selectedMonth);
        _declarations = declarations.ToList();
        ComputeStats();
        _generating = false;
    }

    private void GoToAll() => GoToDeclarations("all");
    private void GoToNotSubmitted() => GoToDeclarations("not_submitted");
    private void GoToSubmitted() => GoToDeclarations("submitted");

    private void GoToDeclarations(string filter)
    {
        Navigation.NavigateTo($"/rozliczenia/declarations?year={_selectedYear}&month={_selectedMonth}&filter={filter}");
    }

    private string GetDonutStyle()
    {
        var notSubmittedDeg = _totalCount > 0 ? 360.0 * _nieZlozoneCount / _totalCount : 180;
        var seg1End = notSubmittedDeg;

        return $"background: conic-gradient(#dc3545 0deg {seg1End:F1}deg, #198754 {seg1End:F1}deg 360deg);";
    }

    private static string GetMonthName(int month) => month switch
    {
        1 => "Styczen", 2 => "Luty", 3 => "Marzec", 4 => "Kwiecien",
        5 => "Maj", 6 => "Czerwiec", 7 => "Lipiec", 8 => "Sierpien",
        9 => "Wrzesien", 10 => "Pazdziernik", 11 => "Listopad", 12 => "Grudzien",
        _ => month.ToString()
    };

    // --- View models ---
    private class FeeTypeRow
    {
        public FeeType FeeType { get; set; }
        public string FeeTypeName { get; set; } = "";
        public string Category { get; set; } = "";
        public int Total { get; set; }
        public int Submitted { get; set; }
        public int NotSubmitted { get; set; }
        public int SubmittedPercent { get; set; }
    }

    private class CategoryStat
    {
        public string CategoryName { get; set; } = "";
        public int Total { get; set; }
        public int Submitted { get; set; }
        public int NotSubmitted { get; set; }
        public int Percent { get; set; }
    }

    private class DeadlineAlert
    {
        public string DeclarationNumber { get; set; } = "";
        public string FeeTypeName { get; set; } = "";
        public DateTime Deadline { get; set; }
        public int DaysLeft { get; set; }
        public bool IsOverdue { get; set; }
    }
}
