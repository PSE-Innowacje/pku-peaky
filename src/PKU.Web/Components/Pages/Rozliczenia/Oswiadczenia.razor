@page "/rozliczenia/oswiadczenia"
@using PKU.Application.Interfaces
@inject IDeclarationService DeclarationService
@rendermode InteractiveServer

<PageTitle>Oswiadczenia rozliczeniowe</PageTitle>

<h3>Oswiadczenia rozliczeniowe</h3>
<p>Lista oswiadczen rozliczeniowych.</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>ID</th>
            <th>Status</th>
            <th>Data zlozenia</th>
            <th>Data utworzenia</th>
            <th>Akcje</th>
        </tr>
    </thead>
    <tbody>
        @if (_declarations is not null)
        {
            @foreach (var declaration in _declarations)
            {
                <tr>
                    <td>@declaration.Id[..8]</td>
                    <td>
                        <span class="badge @GetStatusBadgeClass(declaration.Status)">
                            @declaration.Status
                        </span>
                    </td>
                    <td>@declaration.SubmittedAt.ToString("yyyy-MM-dd")</td>
                    <td>@declaration.CreatedAt.ToString("yyyy-MM-dd")</td>
                    <td>
                        <button class="btn btn-sm btn-outline-primary">Szczegoly</button>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>

@code {
    private IEnumerable<PKU.Domain.Entities.Declaration>? _declarations;

    protected override async Task OnInitializedAsync()
    {
        _declarations = await DeclarationService.GetAllAsync();
    }

    private static string GetStatusBadgeClass(PKU.Domain.Entities.DeclarationStatus status) => status switch
    {
        PKU.Domain.Entities.DeclarationStatus.Draft => "bg-secondary",
        PKU.Domain.Entities.DeclarationStatus.Submitted => "bg-warning",
        PKU.Domain.Entities.DeclarationStatus.InReview => "bg-info",
        PKU.Domain.Entities.DeclarationStatus.Approved => "bg-success",
        PKU.Domain.Entities.DeclarationStatus.Rejected => "bg-danger",
        _ => "bg-secondary"
    };
}
