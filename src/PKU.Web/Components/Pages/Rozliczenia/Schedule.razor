@page "/rozliczenia/schedule"
@attribute [Authorize(Roles = "Kontrahent,Administrator")]
@using PKU.Application.Interfaces
@using PKU.Domain.Entities
@using PKU.Domain.Enums
@using System.Security.Claims
@inject IScheduleService ScheduleService
@inject AuthenticationStateProvider AuthenticationStateProvider
@rendermode InteractiveServer

<PageTitle>Terminarz rozliczen</PageTitle>

<h3>Terminarz rozliczen</h3>
<p>Przeglad aktualnych terminow rozliczen.</p>

@if (_schedules is not null && _schedules.Any())
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Typ oplaty</th>
                <th>Typ kontrahenta</th>
                <th>Skladanie oswiadczenia</th>
                <th>Wystawienie faktury</th>
                <th>Korekta oswiadczenia</th>
                <th>Faktura po korekcie</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var schedule in _schedules.Where(s => s.IsActive))
            {
                <tr>
                    <td>@schedule.FeeType</td>
                    <td>@GetContractorTypeLabel(schedule.ContractorType)</td>
                    <td>@FormatItem(schedule, ScheduleItemType.DeclarationSubmit)</td>
                    <td>@FormatItem(schedule, ScheduleItemType.DeclarationInvoice)</td>
                    <td>@FormatItem(schedule, ScheduleItemType.DeclarationCorrection)</td>
                    <td>@FormatItem(schedule, ScheduleItemType.DeclarationCorrectionInvoice)</td>
                    <td>Aktywny</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <div class="alert alert-info">Brak aktywnych terminarzy.</div>
}

@code {
    private IEnumerable<PKU.Domain.Entities.Schedule>? _schedules;

    protected override async Task OnInitializedAsync()
    {
        var allSchedules = await ScheduleService.GetAllAsync();

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        var role = user.FindFirst(ClaimTypes.Role)?.Value;

        if (role == UserRole.Administrator.ToString())
        {
            _schedules = allSchedules;
        }
        else
        {
            var contractorTypeClaim = user.FindFirst("ContractorType")?.Value;
            var userContractorTypes = contractorTypeClaim?
                .Split(',', StringSplitOptions.RemoveEmptyEntries)
                .Select(t => Enum.Parse<ContractorType>(t.Trim()))
                .ToList() ?? [];

            _schedules = allSchedules
                .Where(s => userContractorTypes.Contains(s.ContractorType));
        }
    }

    private static string FormatItem(PKU.Domain.Entities.Schedule schedule, ScheduleItemType itemType)
    {
        var item = schedule.Items.FirstOrDefault(i => i.ItemType == itemType);
        if (item is null) return "-";
        var dayLabel = item.DayType == DayType.CalendarDay ? "kal." : "rob.";
        return $"{item.Days} dni {dayLabel}";
    }

    private static string GetContractorTypeLabel(ContractorType type) => type switch
    {
        ContractorType.OSDp => "OSDp",
        ContractorType.OSDn => "OSDn",
        ContractorType.Wytworca => "Wytworca",
        ContractorType.Magazyn => "Magazyn",
        ContractorType.OdbiorcaKoncowy => "Odbiorca Koncowy",
        _ => type.ToString()
    };
}
